{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A potential customer who requested a demo.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the lead."
        },
        "company": {
          "type": "string",
          "description": "Company name of the lead."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the lead was created."
        }
      },
      "required": ["name", "email", "company", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of leads who requested a demo."
    }
  }
}
